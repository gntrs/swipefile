# Copy to .env and fill in. Restart `npm run dev` after changing VITE_ vars.
# Only the "Database" block is required to run the app - everything below it is
# optional and unlocks one feature each. Never commit your real .env.

# ------------------------------------------------------------------
# Database (required) - Postgres project URL and keys from your
# database provider's dashboard. The VITE_ pair ships to the browser
# (public by design - row-level security protects the data). The
# service key is local-only, used by the ingest scripts; never expose it.
VITE_DB_URL=
VITE_DB_ANON_KEY=
DB_SERVICE_KEY=
# Set to 1 to allow open self-signup on the login page (default: invite-only).
VITE_ALLOW_SIGNUP=

# ------------------------------------------------------------------
# Your product identity (optional but recommended)
# OWN_BRAND: your brand name exactly as it appears on your ad pages.
# Import scripts use it to tell your own ads apart from competitors;
# skip-own-brand logic only runs when set.
OWN_BRAND=
# APP_NAME: human-readable product name used in bot prompts and alerts.
APP_NAME=

# ------------------------------------------------------------------
# Meta ads (optional - own-ad import + competitor ad library)
# scripts/import-meta-ads.mjs and scripts/import-ad-library.mjs
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
# Separate token for the public Ad Library API (falls back to META_ACCESS_TOKEN).
META_ADLIB_TOKEN=

# ------------------------------------------------------------------
# Foreplay CSV import (optional) - scripts/import-foreplay.mjs
FOREPLAY_API_KEY=

# ------------------------------------------------------------------
# Telegram bot (optional - digests, alerts, chat listener)
# scripts/gm-listener.mjs, scripts/startup-radar.mjs, scripts/health-monitor.mjs
TG_BOT_TOKEN=
TG_CHAT_ID=

# ------------------------------------------------------------------
# Startup radar (optional) - scripts/startup-radar.mjs daily news digest.
# Comma-separated lists; the radar exits with a hint if both are empty.
RADAR_TOPICS=
RADAR_WATCHLIST=
# Subreddits to scan (comma-separated, no r/ prefix).
RADAR_SUBREDDITS=
# IANA timezone for the once-a-day send key (default UTC).
RADAR_TZ=
# Claude CLI binary for the digest LLM pass (default: `claude` on PATH).
RADAR_CLAUDE_BIN=
# Optional extra sources for the radar:
BRAVE_API_KEY=
X_BEARER_TOKEN=

# ------------------------------------------------------------------
# PostHog analytics (optional - traffic pull + health monitor)
# scripts/posthog-pull.mjs, scripts/health-monitor.mjs
POSTHOG_API_KEY=
# Your PostHog project id - the number in your project's URL.
POSTHOG_PROJECT_ID=
# e.g. https://eu.posthog.com or https://us.posthog.com
POSTHOG_HOST=

# ------------------------------------------------------------------
# Health monitor (optional) - scripts/health-monitor.mjs
# When running the monitor, all four below are required, plus
# POSTHOG_API_KEY and POSTHOG_PROJECT_ID from the PostHog block above.
HEALTH_ALERT_TO=
HEALTH_ALERT_FROM=
# Production endpoints to probe when something looks broken:
HEALTH_PROD_API=
HEALTH_PROD_WEB=
# Mailjet pair for the email channel:
MAILJET_API_KEY=
MAILJET_SECRET_KEY=

# ------------------------------------------------------------------
# Stripe revenue (optional) - scripts/stripe-pull.mjs, scripts/revenue-alert.mjs
STRIPE_API_KEY=
# IANA timezone used to bucket revenue by day (default UTC).
REVENUE_TZ=

# ------------------------------------------------------------------
# SEO rank tracking (optional) - scripts/seo-rank-pull.mjs, scripts/trends-pull.mjs
# Your own domain, e.g. example.com (required by the SEO scripts).
SEO_OWN_DOMAIN=
# Comma-separated competitor domains to track alongside yours.
SEO_COMPETITOR_DOMAINS=
