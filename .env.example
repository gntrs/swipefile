# Copy this file to .env and fill in. Restart `npm run dev` after changes.
# Only the two VITE_SUPABASE_* values are required to run the app.

# --- Required: Supabase (client keys are safe to expose; RLS protects data) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Show the self-signup form on the login page. Leave unset in production and
# add teammates from the Supabase dashboard (or scripts/create-users.mjs).
# NOTE: this only hides the form. The real gate is Supabase itself - keep
# "Allow new users to sign up" OFF under Authentication, or anyone could
# create an account against your project's public API and see the library.
VITE_ALLOW_SIGNUP=

# Your own brand name, exactly as you type it when adding your own ads. The
# app uses it to split "our ads" from competitor ads (defaults to "My Brand").
# Set both: VITE_OWN_BRAND is read by the app, OWN_BRAND by the scripts.
VITE_OWN_BRAND=
OWN_BRAND=

# --- Server / scripts only. NEVER commit these; never expose to the browser ---
# Supabase service_role key (Project Settings -> API). Used by the admin
# scripts (create-users, export, importers, snapshots).
SUPABASE_SERVICE_KEY=

# --- Optional integrations (leave blank to disable the related feature) ---
# AI analysis needs no key here: run `node scripts/export.mjs`, then ask
# Claude Code (or the cron wrappers in scripts/) about .claude-data/export.json.

# Revenue card: pull sales from Stripe (scripts/stripe-pull.mjs).
STRIPE_API_KEY=

# Site funnel card: pull product analytics from PostHog.
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=

# Your own ads' real performance from the Meta Marketing API
# (scripts/import-meta-ads.mjs; see that file for how to get a token).
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Ad importers (optional): Foreplay swipe file, Brave creator search.
FOREPLAY_API_KEY=
BRAVE_API_KEY=
